<Window x:Class="NicheStudioWeirdo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Niche Studio Weirdo" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        FontFamily="{StaticResource TerminalFont}"
        TextElement.Foreground="{StaticResource TextLightBrush}">

    <!-- Main Border for Rounded Corners -->
    <Border x:Name="RootBorder" CornerRadius="12" Background="{StaticResource BgDarkestBrush}" BorderThickness="1" BorderBrush="#444" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title Bar -->
                <RowDefinition Height="Auto"/> <!-- Tab Bar -->
                <RowDefinition Height="*"/>    <!-- Content -->
            </Grid.RowDefinitions>

            <!-- macOS Title Bar -->
            <Border Grid.Row="0" Height="32" Background="Transparent" CornerRadius="12,12,0,0" MouseLeftButtonDown="Window_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0,0,0">
                        <Button Width="12" Height="12" Margin="0,0,8,0" Click="Close_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Ellipse Fill="#FF5F56"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Width="12" Height="12" Margin="0,0,8,0" Click="Minimize_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Ellipse Fill="#FFBD2E"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Width="12" Height="12" Margin="0,0,8,0" Click="Maximize_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Ellipse Fill="#27C93F"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="niche-studio — bash" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                </Grid>
            </Border>

            <!-- Top Tab Bar - macOS pill style -->
            <Border Grid.Row="1" Background="{StaticResource BgDarkestBrush}" Padding="10,6,10,6" BorderThickness="0,0,0,1" BorderBrush="#222">
                <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" PanningMode="HorizontalOnly">
                    <StackPanel x:Name="TabContainer" Orientation="Horizontal">
                        <Button Content="Abogado" Style="{StaticResource TabButton}" Click="Nav_Click" Tag="Abogado"/>
                        <Button Content="Buriko" Style="{StaticResource TabButton}" Click="Nav_Click" Tag="BGI"/>
                        <Button Content="CodeXR" Style="{StaticResource TabButton}" Click="Nav_Click" Tag="CodeXR"/>
                        <Button Content="Fuzz Inc." Style="{StaticResource TabButton}" Click="Nav_Click" Tag="FSN"/>
                        <Button Content="HuneX" Style="{StaticResource TabButton}" Click="Nav_Click" Tag="HuneX"/>
                        <Button Content="HuneX (Mahoyo)" Style="{StaticResource TabButton}" Click="Nav_Click" Tag="HuneXMahoyo"/>
                        <Button Content="Leaf" Style="{StaticResource TabButton}" Click="Nav_Click" Tag="WA2"/>
                        <Button Content="Malie" Style="{StaticResource TabButton}" Click="Nav_Click" Tag="MalieKit"/>
                        <Button Content="Malie Kajiri" Style="{StaticResource TabButton}" Click="Nav_Click" Tag="KKK"/>
                        <Button Content="Minato (New)" Style="{StaticResource TabButton}" Click="Nav_Click" Tag="WagaHime"/>
                        <Button Content="Minato (Old)" Style="{StaticResource TabButton}" Click="Nav_Click" Tag="Majikoai"/>
                        <Button Content="Minori" Style="{StaticResource TabButton}" Click="Nav_Click" Tag="Minori"/>
                        <Button Content="TYPE-MOON" Style="{StaticResource TabButton}" Click="Nav_Click" Tag="MeltyBlood"/>
                        <Button Content="YOX" Style="{StaticResource TabButton}" Click="Nav_Click" Tag="Musicus"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Row="2" Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>

                <!-- Dynamic View Container -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                    <StackPanel>
                        <!-- Global Guide Header -->
                        <Grid Margin="0,0,0,10">
                            <Button x:Name="GuideToggle" Content="How to Use" HorizontalAlignment="Right" Style="{StaticResource BrowseButton}" Click="GuideToggle_Click"/>
                        </Grid>
                        
                        <Border x:Name="GuidePanel" Background="{StaticResource BgDarkestBrush}" CornerRadius="0" Padding="15" Margin="0,0,0,20" Visibility="Collapsed" BorderBrush="{StaticResource AccentBlueBrush}" BorderThickness="1">
                            <TextBlock x:Name="GuideText" TextWrapping="Wrap" Foreground="{StaticResource TextLightBrush}" FontSize="13" LineHeight="20"/>
                        </Border>

                        <ContentControl x:Name="MainContent"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Global Console Output -->
                <Border Grid.Row="1" Background="{StaticResource BgDarkestBrush}" CornerRadius="0" Margin="0,20,0,0" Padding="15" BorderThickness="1" BorderBrush="#333">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="user@NicheVNs ~ %" Foreground="{StaticResource TextMutedBrush}" FontSize="11" FontFamily="{StaticResource TerminalFont}" Margin="0,0,0,8"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" x:Name="ConsoleScroll">
                            <TextBlock x:Name="ConsoleOutput" Foreground="#FFFFFF" FontFamily="{StaticResource TerminalFont}" FontSize="13" TextWrapping="Wrap" Text="Ready..."/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
