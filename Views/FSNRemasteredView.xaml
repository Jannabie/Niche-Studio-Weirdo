<UserControl x:Class="NicheStudioWeirdo.Views.FSNRemasteredView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Fuzz Inc." Style="{StaticResource HeaderStyle}"/>
        <TextBlock Grid.Row="1" Text="Decrypt EPK, translate to JSON, and build patches to bypass .bin in Steam." Style="{StaticResource SubheaderStyle}"/>

        <Border Grid.Row="2" Background="{StaticResource BgDarkestBrush}" CornerRadius="0" Padding="20" BorderThickness="1" BorderBrush="{StaticResource BorderBrush2}">
            <StackPanel>
                <!-- Crypto Keys -->
                <TextBlock Text="Crypto Keys" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="decryptKey.bin" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Width="100"/>
                    <TextBox x:Name="DecryptKeyTxt" Grid.Column="1" Style="{StaticResource TextBoxStyle}" Margin="10,0,0,0"/>
                    <Button Grid.Column="2" Content="..." Style="{StaticResource BrowseButton}" Margin="5,0,0,0" Click="BrowseFile_Click" Tag="DecryptKeyTxt"/>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="main.exe" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Width="100"/>
                    <TextBox x:Name="MainExeTxt" Grid.Column="1" Style="{StaticResource TextBoxStyle}" Margin="10,0,0,0"/>
                    <Button Grid.Column="2" Content="..." Style="{StaticResource BrowseButton}" Margin="5,0,0,0" Click="BrowseFile_Click" Tag="MainExeTxt"/>
                </Grid>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="SomeKey.bin" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Width="100"/>
                    <TextBox x:Name="SomeKeyTxt" Grid.Column="1" Style="{StaticResource TextBoxStyle}" Margin="10,0,0,0"/>
                    <Button Grid.Column="2" Content="..." Style="{StaticResource BrowseButton}" Margin="5,0,0,0" Click="BrowseFile_Click" Tag="SomeKeyTxt"/>
                </Grid>

                <!-- Configuration -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Target Locale" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="LocaleCombo" Padding="5" FontSize="14" SelectedIndex="0">
                            <ComboBoxItem Content="English (us)"/>
                            <ComboBoxItem Content="Mandarin (ck)"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="Target Directory / Folder" Style="{StaticResource LabelStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBox x:Name="TargetDirTxt" Grid.Column="0" Style="{StaticResource TextBoxStyle}"/>
                            <Button Grid.Column="1" Content="..." Style="{StaticResource BrowseButton}" Margin="5,0,0,0" Click="BrowseFolder_Click"/>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- Deployment Actions -->
                <TextBlock Text="Deployment Actions" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="Bold" Margin="0,10,0,10"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Build Patch" Style="{StaticResource BrowseButton}" Margin="0,0,8,0" Click="BuildPatch_Click"/>
                    <Button Content="Deploy to Steam" Style="{StaticResource ActionButtonGreen}" Margin="0,0,8,0" Click="DeploySteam_Click"/>
                    <Button Content="Launch Portable" Style="{StaticResource ActionButtonPurple}" Click="LaunchGame_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
