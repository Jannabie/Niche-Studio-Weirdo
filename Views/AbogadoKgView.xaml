<UserControl x:Class="NicheStudioWeirdo.Views.AbogadoKgView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Abogado Graphics (KG)" Style="{StaticResource HeaderStyle}"/>
        <TextBlock Grid.Row="1" Text="Unpack/Repack .DSK archives · Handle format .KG (8bpp/24bpp/32bpp) · Untuk Shuumatsu no Sugoshikata." Style="{StaticResource SubheaderStyle}"/>

        <Border Grid.Row="2" Background="{StaticResource BgDarkestBrush}" CornerRadius="0" Padding="20" BorderThickness="1" BorderBrush="{StaticResource BorderBrush2}" Margin="0,0,0,0">
            <StackPanel>

                <!-- ── DSK Archive ── -->
                <TextBlock Text="TARGET .DSK ARCHIVE" Style="{StaticResource LabelStyle}"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox x:Name="DskFileTxt" Grid.Column="0" Style="{StaticResource TextBoxStyle}" ToolTip="File arsip .DSK yang berisi semua gambar .KG"/>
                    <Button Grid.Column="1" Content="Browse" Style="{StaticResource BrowseButton}" Margin="8,0,0,0" Click="BrowseDsk_Click"/>
                </Grid>

                <!-- ── PFT Index ── -->
                <TextBlock Text="INDEX .PFT FILE (wajib untuk semua operasi)" Style="{StaticResource LabelStyle}"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox x:Name="PftFileTxt" Grid.Column="0" Style="{StaticResource TextBoxStyle}" ToolTip="File index .PFT pasangan dari .DSK"/>
                    <Button Grid.Column="1" Content="Browse" Style="{StaticResource BrowseButton}" Margin="8,0,0,0" Click="BrowsePft_Click"/>
                </Grid>

                <!-- ── Working Folder ── -->
                <TextBlock Text="WORKING FOLDER (output unpack .KG · input PNG→KG · input patch)" Style="{StaticResource LabelStyle}"/>
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox x:Name="WorkFolderTxt" Grid.Column="0" Style="{StaticResource TextBoxStyle}"
                             ToolTip="Output saat Unpack DSK (file .KG). Juga digunakan sebagai folder PNG saat PNG→KG Convert, dan folder .KG saat Patch/Rebuild."/>
                    <Button Grid.Column="1" Content="Browse" Style="{StaticResource BrowseButton}" Margin="8,0,0,0" Click="BrowseWorkFolder_Click"/>
                </Grid>

                <!-- Workflow Banner -->
                <Border Background="#0D1A0D" CornerRadius="0" Padding="12" Margin="0,0,0,20" BorderThickness="1" BorderBrush="#2A4030">
                    <StackPanel>
                        <TextBlock Foreground="#70C080" FontSize="11" FontWeight="Bold" Text="WORKFLOW:" Margin="0,0,0,4"/>
                        <TextBlock Foreground="#90B898" FontSize="11" TextWrapping="Wrap"
                                   Text="① Unpack DSK (otomatis extract .KG & decode ke .PNG) ATAU Decode Folder mentah   ②  Edit .PNG   ③  PNG→KG Convert   ④  Patch In-place atau Rebuild DSK"/>
                    </StackPanel>
                </Border>

                <!-- Note Banner -->
                <Border Background="#1A1508" CornerRadius="0" Padding="12" Margin="0,0,0,20" BorderThickness="1" BorderBrush="#3A3015">
                    <TextBlock Foreground="#B09040" FontSize="11" TextWrapping="Wrap"
                               Text="Note: Pastikan kg_metadata.json ada di folder PNG (berisi info BPP asli tiap gambar) sebelum PNG→KG Convert. Patch In-place akan membaca dari subfolder packed_kg/ jika ada."/>
                </Border>

                <!-- Buttons Row -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Unpack DSK" Style="{StaticResource BrowseButton}" Margin="0,0,8,0"
                            Click="UnpackDsk_Click"
                            ToolTip="[ArcUNPACK.py Mode 1] Ekstrak semua .KG dari archive .DSK ke Working Folder & otomatis decode jadi PNG"/>
                    <Button Content="Decode Folder" Style="{StaticResource BrowseButton}" Margin="0,0,8,0"
                            Click="DecodeFolder_Click"
                            ToolTip="[ArcUNPACK.py Mode 2] Decode semua file raw .KG/.SCF di Working Folder menjadi .PNG"/>
                    <Button Content="PNG → KG Convert" Style="{StaticResource BrowseButton}" Margin="0,0,8,0"
                            Click="ConvertPngKg_Click"
                            ToolTip="[ArcKGPACK.py] Konversi file .PNG di Working Folder ke format .KG (output ke packed_kg/)"/>
                    <Button Content="Patch DSK In-place" Style="{StaticResource ActionButtonAmber}" Margin="0,0,8,0"
                            Click="PatchDsk_Click"
                            ToolTip="[ArcPATCH.py] Suntik file .KG dari packed_kg/ ke dalam .DSK tanpa rebuild ulang"/>
                    <Button Content="Rebuild Full DSK" Style="{StaticResource ActionButtonGreen}"
                            Click="RebuildDsk_Click"
                            ToolTip="[ArcPACK.py] Bangun archive .DSK + .PFT baru dari semua file .KG di Working Folder"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
