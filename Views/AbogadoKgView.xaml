<UserControl x:Class="NicheStudioWeirdo.Views.AbogadoKgView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Abogado Graphics (KG)" Style="{StaticResource HeaderStyle}"/>
        <TextBlock Grid.Row="1" Text="Convert PNG to KG (8bpp/24bpp/32bpp) and pack/patch .DSK archives." Style="{StaticResource SubheaderStyle}"/>

        <Border Grid.Row="2" Background="{StaticResource BgDarkestBrush}" CornerRadius="0" Padding="20" BorderThickness="1" BorderBrush="{StaticResource BorderBrush2}" Margin="0,0,0,0">
            <StackPanel>
                <TextBlock Text="PNG SOURCE FOLDER (Tahap 1)" Style="{StaticResource LabelStyle}"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox x:Name="PngFolderTxt" Grid.Column="0" Style="{StaticResource TextBoxStyle}"/>
                    <Button Grid.Column="1" Content="Browse" Style="{StaticResource BrowseButton}" Margin="8,0,0,0" Click="BrowsePngFolder_Click"/>
                </Grid>

                <TextBlock Text="TARGET .DSK ARCHIVE (Tahap 2)" Style="{StaticResource LabelStyle}"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox x:Name="DskFileTxt" Grid.Column="0" Style="{StaticResource TextBoxStyle}"/>
                    <Button Grid.Column="1" Content="Browse" Style="{StaticResource BrowseButton}" Margin="8,0,0,0" Click="BrowseDsk_Click"/>
                </Grid>

                <TextBlock Text="INDEX .PFT FILE (Wajib untuk Patch/Rebuild)" Style="{StaticResource LabelStyle}"/>
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox x:Name="PftFileTxt" Grid.Column="0" Style="{StaticResource TextBoxStyle}"/>
                    <Button Grid.Column="1" Content="Browse" Style="{StaticResource BrowseButton}" Margin="8,0,0,0" Click="BrowsePft_Click"/>
                </Grid>

                <!-- Warning Banner -->
                <Border Background="#1A1508" CornerRadius="0" Padding="12" Margin="0,0,0,20" BorderThickness="1" BorderBrush="#3A3015">
                    <TextBlock Text="Note: Ensure kg_metadata.json is present in your PNG folder if packing 8bpp images." Foreground="#B09040" FontSize="12" TextWrapping="Wrap"/>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Unpack DSK" Style="{StaticResource BrowseButton}" Margin="0,0,8,0" Click="UnpackDsk_Click" ToolTip="Runs ArcUNPACK.py"/>
                    <Button Content="PNG -> KG Convert" Style="{StaticResource BrowseButton}" Margin="0,0,8,0" Click="ConvertPngKg_Click" ToolTip="Runs ArcKGPACK.py"/>
                    <Button Content="Patch DSK In-place" Style="{StaticResource ActionButtonAmber}" Margin="0,0,8,0" Click="PatchDsk_Click" ToolTip="Runs ArcPATCH.py"/>
                    <Button Content="Rebuild Full DSK" Style="{StaticResource ActionButtonGreen}" Click="RebuildDsk_Click" ToolTip="Runs ArcPACK.py"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
