<UserControl x:Class="NicheStudioWeirdo.Views.MajikaiView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Minato (Old)" Style="{StaticResource HeaderStyle}"/>
        <TextBlock Grid.Row="1" Text="Unpack .pac archives and extract/repack .bin script SEG blocks." Style="{StaticResource SubheaderStyle}"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- PAC Archive Operations -->
            <Border Grid.Column="0" Background="{StaticResource BgDarkestBrush}" CornerRadius="0" Padding="20" BorderThickness="1" BorderBrush="{StaticResource BorderBrush2}">
                <StackPanel>
                    <TextBlock Text="PAC Archive Operations" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="Bold" Margin="0,0,0,15"/>

                    <TextBlock Text="Target .pac File" Style="{StaticResource LabelStyle}"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="PacFileTxt" Grid.Column="0" Style="{StaticResource TextBoxStyle}"/>
                        <Button Grid.Column="1" Content="..." Style="{StaticResource BrowseButton}" Margin="5,0,0,0" Click="BrowsePac_Click"/>
                    </Grid>

                    <TextBlock Text="Output Folder" Style="{StaticResource LabelStyle}"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="PacOutTxt" Grid.Column="0" Style="{StaticResource TextBoxStyle}"/>
                        <Button Grid.Column="1" Content="..." Style="{StaticResource BrowseButton}" Margin="5,0,0,0" Click="BrowsePacOut_Click"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Unpack PAC" Style="{StaticResource BrowseButton}" Margin="0,0,8,0" Click="UnpackPac_Click"/>
                        <Button Content="Repack PAC" Style="{StaticResource ActionButtonGreen}" Click="RepackPac_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- BIN Script Operations -->
            <Border Grid.Column="2" Background="{StaticResource BgDarkestBrush}" CornerRadius="0" Padding="20" BorderThickness="1" BorderBrush="{StaticResource BorderBrush2}">
                <StackPanel>
                    <TextBlock Text="BIN Script Operations" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="Bold" Margin="0,0,0,15"/>

                    <TextBlock Text=".bin Script File" Style="{StaticResource LabelStyle}"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="BinFileTxt" Grid.Column="0" Style="{StaticResource TextBoxStyle}"/>
                        <Button Grid.Column="1" Content="..." Style="{StaticResource BrowseButton}" Margin="5,0,0,0" Click="BrowseBin_Click"/>
                    </Grid>

                    <TextBlock Text="Repack Mode" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="RepackModeCombo" Margin="0,0,0,20" Padding="5" FontSize="14" SelectedIndex="0">
                        <ComboBoxItem Content="Preserve (Fixed Offset  Epad bytes)"/>
                        <ComboBoxItem Content="Rebuild (Dynamic Length  Eresize offsets)"/>
                    </ComboBox>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Extract BIN -> SEG" Style="{StaticResource BrowseButton}" Margin="0,0,8,0" Click="ExtractBin_Click"/>
                        <Button Content="Repack BIN" Style="{StaticResource ActionButtonGreen}" Click="RepackBin_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
