<UserControl x:Class="NicheStudioWeirdo.Views.MinoriView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Minori" Style="{StaticResource HeaderStyle}"/>
        <TextBlock Grid.Row="1" Text="Unpack .paz archives and repack folders using fuckpaz.exe. Select game index from the list." Style="{StaticResource SubheaderStyle}"/>

        <Border Grid.Row="2" Background="{StaticResource BgDarkestBrush}" CornerRadius="0" Padding="20" BorderThickness="1" BorderBrush="{StaticResource BorderBrush2}">
            <StackPanel>
                <!-- Game Index -->
                <TextBlock Text="GAME INDEX" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="GameIndexCombo" Margin="0,0,0,20" Padding="8,6" FontSize="12" SelectedIndex="0"
                          Background="{StaticResource BgDarkestBrush}" Foreground="{StaticResource TextLightBrush}" BorderBrush="{StaticResource BorderBrush2}">
                    <ComboBoxItem Content="0   ef &#x2013; the first tale (jp)"/>
                    <ComboBoxItem Content="1   ef &#x2013; the first tale (en)"/>
                    <ComboBoxItem Content="2   ef &#x2013; the first tale (en steam)"/>
                    <ComboBoxItem Content="3   ef &#x2013; the latter tale (jp)"/>
                    <ComboBoxItem Content="4   ef &#x2013; the latter tale (en NNL)"/>
                    <ComboBoxItem Content="5   ef &#x2013; the latter tale (en)"/>
                    <ComboBoxItem Content="6   ef &#x2013; the latter tale (en steam)"/>
                    <ComboBoxItem Content="7   eden* (jp)"/>
                    <ComboBoxItem Content="8   eden* (en steam)"/>
                    <ComboBoxItem Content="9   eden* PLUS+MOSAIC (en steam)"/>
                    <ComboBoxItem Content="10  Mashiro Iro Symphony (jp)"/>
                    <ComboBoxItem Content="11  Riddle Garden (jp)"/>
                    <ComboBoxItem Content="12  Steal My Heart ~Rhapsody of Moonlight~ (jp)"/>
                    <ComboBoxItem Content="13  Tenshi no Nichiyoubi (ef a fairy tale of the two.)"/>
                    <ComboBoxItem Content="14  Supipara Story #01 - Spring Has Come! (jp)"/>
                    <ComboBoxItem Content="15  Natsuzora no Perseus (jp)"/>
                    <ComboBoxItem Content="16  12 no Tsuki no Eve (jp)"/>
                    <ComboBoxItem Content="17  Soreyori no Prologue (jp)"/>
                    <ComboBoxItem Content="18  Soreyori no Prologue Append H (jp)"/>
                    <ComboBoxItem Content="19  Tsumi no Hikari Rendezvous (jp)"/>
                    <ComboBoxItem Content="20  Tsumi no Hikari Rendezvous Mikan Blossom (jp)"/>
                    <ComboBoxItem Content="21  Trinoline (jp)"/>
                    <ComboBoxItem Content="22  Trinoline (en steam)"/>
                    <ComboBoxItem Content="23  Trinoline: Genesis (jp)"/>
                    <ComboBoxItem Content="24  Trinoline: Genesis (en steam)"/>
                    <ComboBoxItem Content="25  Sono Hi no Kemono ni wa, (jp)"/>
                </ComboBox>

                <!-- Extraction Settings -->
                <TextBlock Text="Extraction Settings (Unpack)" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                
                <TextBlock Text="TARGET .PAZ FILE" Style="{StaticResource LabelStyle}"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox x:Name="PazFileTxt" Grid.Column="0" Style="{StaticResource TextBoxStyle}"/>
                    <Button Grid.Column="1" Content="Browse" Style="{StaticResource BrowseButton}" Margin="8,0,0,0" Click="BrowsePaz_Click"/>
                </Grid>

                <TextBlock Text="OUTPUT FOLDER (Optional - defaults to PAZ directory)" Style="{StaticResource LabelStyle}"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox x:Name="ExtractFolderTxt" Grid.Column="0" Style="{StaticResource TextBoxStyle}"/>
                    <Button Grid.Column="1" Content="Browse" Style="{StaticResource BrowseButton}" Margin="8,0,0,0" Click="BrowseExtractFolder_Click"/>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,20">
                    <Button Content="Unpack PAZ" Style="{StaticResource BrowseButton}" Click="Unpack_Click"/>
                </StackPanel>

                <!-- Repack Settings -->
                <TextBlock Text="Repack Settings" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="Bold" Margin="0,10,0,10"/>

                <TextBlock Text="TARGET ORIGINAL .PAZ FILE (Required for keys &amp; TOC)" Style="{StaticResource LabelStyle}"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox x:Name="RepackOriginalPazTxt" Grid.Column="0" Style="{StaticResource TextBoxStyle}"/>
                    <Button Grid.Column="1" Content="Browse" Style="{StaticResource BrowseButton}" Margin="8,0,0,0" Click="BrowseRepackOriginalPaz_Click"/>
                </Grid>

                <TextBlock Text="TARGET FOLDER (Exact folder containing the unpacked files)" Style="{StaticResource LabelStyle}"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox x:Name="RepackFolderTxt" Grid.Column="0" Style="{StaticResource TextBoxStyle}"/>
                    <Button Grid.Column="1" Content="Browse" Style="{StaticResource BrowseButton}" Margin="8,0,0,0" Click="BrowseRepackFolder_Click"/>
                </Grid>

                <TextBlock Text="OUTPUT .PAZ NAME (e.g., scr_patched.paz)" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="OutputPazTxt" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,20" Text="scr_patched.paz"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Repack PAZ" Style="{StaticResource ActionButtonGreen}" Click="Repack_Click"/>
                </StackPanel>

                <!-- How to use note -->
                <Border Background="#080808" CornerRadius="0"
                        Padding="16,12" Margin="0,14,0,0"
                        BorderThickness="1" BorderBrush="#222">
                    <StackPanel>
                        <TextBlock Foreground="#555" FontWeight="Bold" FontSize="11" Text="HOW TO USE REPACK:"/>
                        <TextBlock Foreground="#444" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"
                                   Text="① TARGET ORIGINAL .PAZ FILE  →  select the original .paz from the game folder (e.g. scr.paz). Used for encryption keys and file table."/>
                        <TextBlock Foreground="#444" FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap"
                                   Text="② TARGET FOLDER  →  select the folder that DIRECTLY contains the unpacked files (e.g. the .sc files). Do NOT select a parent folder."/>
                        <TextBlock Foreground="#444" FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap"
                                   Text="③ OUTPUT .PAZ NAME  →  filename for the repacked archive (saved inside TARGET FOLDER)."/>
                        <TextBlock Foreground="#444" FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap"
                                   Text="④ Make sure GAME INDEX matches your game before repacking."/>
                        <TextBlock Foreground="#444" FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap"
                                   Text="⑤ Copy the output .paz to the game folder to replace the original."/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
