<UserControl x:Class="NicheStudioWeirdo.Views.AbogadoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Abogado" Style="{StaticResource HeaderStyle}"/>
        <TextBlock Grid.Row="1" Text="Parse .SCF scripts, inject translations, convert PNG↔KG, and patch/rebuild .DSK archives." Style="{StaticResource SubheaderStyle}"/>

        <!-- Custom Tab Row -->
        <StackPanel Grid.Row="2">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                <Button x:Name="TabScf" Content="Script (.SCF)" Style="{StaticResource BrowseButton}" Click="SwitchTab_Click" Tag="SCF" Margin="0,0,4,0"/>
                <Button x:Name="TabGfx" Content="Graphics (.KG / .DSK)" Style="{StaticResource BrowseButton}" Click="SwitchTab_Click" Tag="GFX"/>
            </StackPanel>

            <!-- SCF Panel -->
            <Border x:Name="PanelScf" Background="{StaticResource BgDarkestBrush}" CornerRadius="0" Padding="20" BorderThickness="1" BorderBrush="{StaticResource BorderBrush2}" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="SOURCE .SCF FILE" Style="{StaticResource LabelStyle}"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="ScfFileTxt" Grid.Column="0" Style="{StaticResource TextBoxStyle}"/>
                        <Button Grid.Column="1" Content="Browse" Style="{StaticResource BrowseButton}" Margin="8,0,0,0" Click="BrowseScf_Click"/>
                    </Grid>

                    <TextBlock Text="TRANSLATION JSON FILE" Style="{StaticResource LabelStyle}"/>
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="TranslationJsonTxt" Grid.Column="0" Style="{StaticResource TextBoxStyle}"/>
                        <Button Grid.Column="1" Content="Browse" Style="{StaticResource BrowseButton}" Margin="8,0,0,0" Click="BrowseJson_Click"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Parse SCF -> JSON" Style="{StaticResource BrowseButton}" Margin="0,0,8,0" Click="ParseScf_Click"/>
                        <Button Content="Inject Translation" Style="{StaticResource ActionButton}" Margin="0,0,8,0" Click="InjectTranslation_Click"/>
                        <Button Content="Verify Integrity" Style="{StaticResource ActionButtonPurple}" Click="VerifyIntegrity_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- GFX Panel (hidden by default) -->
            <Border x:Name="PanelGfx" Background="{StaticResource BgDarkestBrush}" CornerRadius="0" Padding="20" BorderThickness="1" BorderBrush="{StaticResource BorderBrush2}" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="PNG SOURCE FOLDER" Style="{StaticResource LabelStyle}"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="PngFolderTxt" Grid.Column="0" Style="{StaticResource TextBoxStyle}"/>
                        <Button Grid.Column="1" Content="Browse" Style="{StaticResource BrowseButton}" Margin="8,0,0,0" Click="BrowsePngFolder_Click"/>
                    </Grid>

                    <TextBlock Text="TARGET .DSK ARCHIVE" Style="{StaticResource LabelStyle}"/>
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="DskFileTxt" Grid.Column="0" Style="{StaticResource TextBoxStyle}"/>
                        <Button Grid.Column="1" Content="Browse" Style="{StaticResource BrowseButton}" Margin="8,0,0,0" Click="BrowseDsk_Click"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="PNG -> KG Convert" Style="{StaticResource BrowseButton}" Margin="0,0,8,0" Click="ConvertPngKg_Click"/>
                        <Button Content="Patch DSK In-place" Style="{StaticResource ActionButtonAmber}" Margin="0,0,8,0" Click="PatchDsk_Click"/>
                        <Button Content="Rebuild Full DSK" Style="{StaticResource ActionButtonGreen}" Click="RebuildDsk_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
