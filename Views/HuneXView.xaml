<UserControl x:Class="NicheStudioWeirdo.Views.HuneXView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="HuneX (Tsukihime)" Style="{StaticResource HeaderStyle}"/>
        <TextBlock Grid.Row="1" Text="Extract script_text.mrg to .txt, edit, then repack back to .mrg." Style="{StaticResource SubheaderStyle}"/>

        <StackPanel Grid.Row="2">
            <Border Background="{StaticResource BgDarkestBrush}" Padding="24" BorderThickness="1" BorderBrush="{StaticResource BorderBrush2}">
                <StackPanel>

                    <!-- EXTRACT -->
                    <TextBlock Text="EXTRACT  —  script_text.mrg → .txt" Style="{StaticResource LabelStyle}" Foreground="{StaticResource TextLightBrush}" FontSize="13" Margin="0,0,0,12"/>

                    <TextBlock Text="SCRIPT_TEXT.MRG" Style="{StaticResource LabelStyle}"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="MrgInputTxt" Grid.Column="0" Style="{StaticResource TextBoxStyle}"/>
                        <Button Grid.Column="1" Content="..." Style="{StaticResource BrowseButton}" Margin="5,0,0,0" Click="BrowseMrgInput_Click"/>
                    </Grid>

                    <TextBlock Text="OUTPUT .TXT" Style="{StaticResource LabelStyle}"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="ExtractOutputTxt" Grid.Column="0" Style="{StaticResource TextBoxStyle}"/>
                        <Button Grid.Column="1" Content="..." Style="{StaticResource BrowseButton}" Margin="5,0,0,0" Click="BrowseExtractOutput_Click"/>
                    </Grid>

                    <Button Content="Extract → .TXT" Style="{StaticResource ActionButtonGreen}" HorizontalAlignment="Right" Padding="20,8" Margin="0,0,0,28" Click="Extract_Click"/>

                    <Border Height="1" Background="{StaticResource BorderBrush2}" Margin="0,0,0,24"/>

                    <!-- REPACK -->
                    <TextBlock Text="REPACK  —  .txt → script_text_new.mrg" Style="{StaticResource LabelStyle}" Foreground="{StaticResource TextLightBrush}" FontSize="13" Margin="0,0,0,12"/>

                    <TextBlock Text="INPUT .TXT (EDITED)" Style="{StaticResource LabelStyle}"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="RepackInputTxt" Grid.Column="0" Style="{StaticResource TextBoxStyle}"/>
                        <Button Grid.Column="1" Content="..." Style="{StaticResource BrowseButton}" Margin="5,0,0,0" Click="BrowseRepackInput_Click"/>
                    </Grid>

                    <TextBlock Text="OUTPUT .MRG" Style="{StaticResource LabelStyle}"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="RepackOutputTxt" Grid.Column="0" Style="{StaticResource TextBoxStyle}"/>
                        <Button Grid.Column="1" Content="..." Style="{StaticResource BrowseButton}" Margin="5,0,0,0" Click="BrowseRepackOutput_Click"/>
                    </Grid>

                    <Button Content="Repack → .MRG" Style="{StaticResource ActionButtonGreen}" HorizontalAlignment="Right" Padding="20,8" Click="Repack_Click"/>

                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
