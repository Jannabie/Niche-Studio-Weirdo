<UserControl x:Class="NicheStudioWeirdo.Views.AbogadoSdkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Abogado Script (SDK)" Style="{StaticResource HeaderStyle}"/>
        <TextBlock Grid.Row="1" Text="Extract Shift-JIS text from .SCF files to JSON and inject translated text back." Style="{StaticResource SubheaderStyle}"/>

        <Border Grid.Row="2" Background="{StaticResource BgDarkestBrush}" CornerRadius="0" Padding="20" BorderThickness="1" BorderBrush="{StaticResource BorderBrush2}" Margin="0,0,0,0">
            <StackPanel>
                <TextBlock Text="SOURCE .SCF FILE" Style="{StaticResource LabelStyle}"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox x:Name="ScfFileTxt" Grid.Column="0" Style="{StaticResource TextBoxStyle}"/>
                    <Button Grid.Column="1" Content="Browse" Style="{StaticResource BrowseButton}" Margin="8,0,0,0" Click="BrowseScf_Click"/>
                </Grid>

                <TextBlock Text="TRANSLATION JSON FILE" Style="{StaticResource LabelStyle}"/>
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBox x:Name="TranslationJsonTxt" Grid.Column="0" Style="{StaticResource TextBoxStyle}"/>
                    <Button Grid.Column="1" Content="Browse" Style="{StaticResource BrowseButton}" Margin="8,0,0,0" Click="BrowseJson_Click"/>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Parse SCF -> JSON" Style="{StaticResource BrowseButton}" Margin="0,0,8,0" Click="ParseScf_Click" ToolTip="Runs parser_scf.py"/>
                    <Button Content="Inject Translation" Style="{StaticResource ActionButton}" Margin="0,0,8,0" Click="InjectTranslation_Click" ToolTip="Runs injector_scf.py"/>
                    <Button Content="Verify Integrity" Style="{StaticResource ActionButtonPurple}" Click="VerifyIntegrity_Click" ToolTip="Runs sdk_verify.py"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
